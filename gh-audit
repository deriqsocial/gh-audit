#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.0"
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

SINCE="${GH_AUDIT_SINCE:-7}"
WARNINGS=0
ALERTS=0

warn()  { ((WARNINGS++)); echo -e "  ${YELLOW}⚠  $1${NC}"; }
alert() { ((ALERTS++));   echo -e "  ${RED}🚨 $1${NC}"; }
ok()    { echo -e "  ${GREEN}✓  $1${NC}"; }
info()  { echo -e "  ${DIM}$1${NC}"; }
header(){ echo -e "\n${CYAN}${BOLD}[$1]${NC}"; }

usage() {
  cat <<EOF
${BOLD}gh-audit${NC} v${VERSION} — GitHub repository security audit

Checks your repos for signs of unauthorized access:
  • Unexpected collaborators & pending invitations
  • Deploy keys (especially recent ones)
  • Webhooks pointing to unknown URLs
  • Recent workflow file changes
  • Suspicious commits from unknown authors
  • Repo visibility changes
  • Branch protection status

${BOLD}Usage:${NC}
  gh-audit [options] [owner/repo ...]

${BOLD}Options:${NC}
  -a, --all          Audit all repos you own (up to 100)
  -o, --org ORG      Audit all repos in an organization
  -d, --days N       Look back N days (default: 7)
  -q, --quiet        Only show warnings and alerts
  --no-color         Disable colored output
  -h, --help         Show this help
  -v, --version      Show version

${BOLD}Examples:${NC}
  gh-audit myorg/myrepo
  gh-audit --all --days 14
  gh-audit -o my-company
  gh-audit owner/repo1 owner/repo2

${BOLD}Requirements:${NC}
  • GitHub CLI (gh) authenticated
EOF
  exit 0
}

ALL=false
ORG=""
QUIET=false
REPOS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    -v|--version) echo "gh-audit v${VERSION}"; exit 0 ;;
    -a|--all) ALL=true; shift ;;
    -o|--org) ORG="$2"; shift 2 ;;
    -d|--days) SINCE="$2"; shift 2 ;;
    -q|--quiet) QUIET=true; shift ;;
    --no-color) RED=""; YELLOW=""; GREEN=""; CYAN=""; BOLD=""; DIM=""; NC=""; shift ;;
    -*) echo "Unknown option: $1"; exit 1 ;;
    *) REPOS+=("$1"); shift ;;
  esac
done

if ! command -v gh &>/dev/null; then
  echo "Error: GitHub CLI (gh) is required. Install: https://cli.github.com"
  exit 1
fi

if ! command -v jq &>/dev/null; then
  echo "Error: jq is required. Install: https://jqlang.github.io/jq/download/"
  exit 1
fi

if ! gh auth status &>/dev/null 2>&1; then
  echo "Error: Not authenticated. Run: gh auth login"
  exit 1
fi

AUTHED_USER=$(gh api user -q .login 2>/dev/null)
SINCE_DATE=$(date -v-${SINCE}d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -d "${SINCE} days ago" --iso-8601=seconds 2>/dev/null)

if [[ ${#REPOS[@]} -eq 0 && "$ALL" == false && -z "$ORG" ]]; then
  REMOTE=$(git remote get-url origin 2>/dev/null || true)
  if [[ -n "$REMOTE" ]]; then
    REPO=$(echo "$REMOTE" | sed -E 's#.*github\.com[:/]([^/]+/[^/.]+)(\.git)?$#\1#')
    if [[ -n "$REPO" && "$REPO" != "$REMOTE" ]]; then
      REPOS+=("$REPO")
    fi
  fi
  if [[ ${#REPOS[@]} -eq 0 ]]; then
    echo "No repo specified. Use --all, --org, or pass owner/repo."
    echo "Run gh-audit --help for usage."
    exit 1
  fi
fi

if [[ "$ALL" == true ]]; then
  while IFS= read -r line; do REPOS+=("$line"); done < <(gh repo list --limit 100 --json nameWithOwner -q '.[].nameWithOwner')
fi

if [[ -n "$ORG" ]]; then
  while IFS= read -r line; do REPOS+=("$line"); done < <(gh repo list "$ORG" --limit 100 --json nameWithOwner -q '.[].nameWithOwner')
fi

audit_repo() {
  local repo="$1"
  local repo_warnings=0
  local repo_alerts=0

  echo -e "\n${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${BOLD}  Auditing: ${CYAN}$repo${NC}"
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

  # --- Repo metadata ---
  header "Repository Info"
  local repo_info
  repo_info=$(gh api "repos/$repo" 2>/dev/null || echo "{}")
  local visibility=$(echo "$repo_info" | jq -r '.visibility // "unknown"')
  local default_branch=$(echo "$repo_info" | jq -r '.default_branch // "main"')
  info "Visibility: $visibility | Default branch: $default_branch"

  # --- Collaborators ---
  header "Collaborators"
  local collabs
  collabs=$(gh api "repos/$repo/collaborators" --paginate 2>/dev/null || echo "[]")
  local collab_count=$(echo "$collabs" | jq 'length')

  if [[ "$collab_count" -gt 0 ]]; then
    echo "$collabs" | jq -r '.[] | "  \(.login) (\(.role_name // "unknown"))"' 2>/dev/null
    if [[ "$collab_count" -gt 10 ]]; then
      warn "$collab_count collaborators — verify this list"
    else
      ok "$collab_count collaborator(s)"
    fi
  else
    ok "No outside collaborators"
  fi

  # --- Pending invitations ---
  local invites
  invites=$(gh api "repos/$repo/invitations" 2>/dev/null || echo "[]")
  local invite_count=$(echo "$invites" | jq 'length')
  if [[ "$invite_count" -gt 0 ]]; then
    alert "$invite_count pending invitation(s):"
    echo "$invites" | jq -r '.[] | "    → \(.invitee.login // "unknown") invited by \(.inviter.login // "unknown") on \(.created_at)"'
  else
    ok "No pending invitations"
  fi

  # --- Deploy keys ---
  header "Deploy Keys"
  local keys
  keys=$(gh api "repos/$repo/keys" 2>/dev/null || echo "[]")
  local key_count=$(echo "$keys" | jq 'length')

  if [[ "$key_count" -gt 0 ]]; then
    warn "$key_count deploy key(s) found:"
    echo "$keys" | jq -r '.[] | "    \(.title) | read_only=\(.read_only) | created=\(.created_at)"'
    local recent_keys=$(echo "$keys" | jq --arg since "$SINCE_DATE" '[.[] | select(.created_at > $since)] | length')
    if [[ "$recent_keys" -gt 0 ]]; then
      alert "$recent_keys deploy key(s) added in the last ${SINCE} days!"
    fi
  else
    ok "No deploy keys"
  fi

  # --- Webhooks ---
  header "Webhooks"
  local hooks
  hooks=$(gh api "repos/$repo/hooks" 2>/dev/null || echo "[]")
  local hook_count=$(echo "$hooks" | jq 'length')

  if [[ "$hook_count" -gt 0 ]]; then
    warn "$hook_count webhook(s) configured:"
    echo "$hooks" | jq -r '.[] | "    \(.config.url // "no-url") | events=\(.events | join(",")) | active=\(.active) | created=\(.created_at)"'
    local recent_hooks=$(echo "$hooks" | jq --arg since "$SINCE_DATE" '[.[] | select(.created_at > $since)] | length')
    if [[ "$recent_hooks" -gt 0 ]]; then
      alert "$recent_hooks webhook(s) added in the last ${SINCE} days!"
    fi
  else
    ok "No webhooks"
  fi

  # --- Workflow files changed recently ---
  header "GitHub Actions (workflow changes in last ${SINCE} days)"
  local workflow_commits
  workflow_commits=$(gh api "repos/$repo/commits?path=.github/workflows&since=$SINCE_DATE&per_page=20" 2>/dev/null || echo "[]")
  local wf_count=$(echo "$workflow_commits" | jq 'if type == "array" then length else 0 end' 2>/dev/null || echo "0")

  if [[ "$wf_count" -gt 0 ]]; then
    alert "$wf_count commit(s) touching workflow files:"
    echo "$workflow_commits" | jq -r '.[] | "    \(.sha[0:8]) by \(.commit.author.name // "unknown") <\(.commit.author.email // "?")> — \(.commit.message | split("\n")[0])"'
  else
    ok "No workflow changes"
  fi

  # --- Recent commits from unknown authors ---
  header "Recent Commits (last ${SINCE} days)"
  local recent_commits
  recent_commits=$(gh api "repos/$repo/commits?since=$SINCE_DATE&per_page=50" 2>/dev/null || echo "[]")
  local commit_count=$(echo "$recent_commits" | jq 'if type == "array" then length else 0 end' 2>/dev/null || echo "0")

  if [[ "$commit_count" -gt 0 ]]; then
    info "$commit_count commit(s) in window"
    local unknown_authors
    unknown_authors=$(echo "$recent_commits" | jq -r '[.[] | select(.author == null)] | length')
    if [[ "$unknown_authors" -gt 0 ]]; then
      warn "$unknown_authors commit(s) from unlinked GitHub accounts:"
      echo "$recent_commits" | jq -r '.[] | select(.author == null) | "    \(.sha[0:8]) by \(.commit.author.name) <\(.commit.author.email)> — \(.commit.message | split("\n")[0])"'
    fi

    local force_pushes
    force_pushes=$(gh api "repos/$repo/events?per_page=30" 2>/dev/null | jq --arg since "$SINCE_DATE" '[.[] | select(.type == "PushEvent" and .payload.forced == true and .created_at > $since)] | length' 2>/dev/null || echo "0")
    if [[ "$force_pushes" -gt 0 ]]; then
      alert "$force_pushes force push(es) detected!"
    fi
  else
    ok "No commits in window"
  fi

  # --- Branch protection ---
  header "Branch Protection ($default_branch)"
  local protection
  protection=$(gh api "repos/$repo/branches/$default_branch/protection" 2>/dev/null || echo "NONE")

  if [[ "$protection" == "NONE" || $(echo "$protection" | jq 'has("message")' 2>/dev/null) == "true" ]]; then
    warn "No branch protection on $default_branch"
  else
    local pr_required=$(echo "$protection" | jq '.required_pull_request_reviews != null' 2>/dev/null)
    local status_checks=$(echo "$protection" | jq '.required_status_checks != null' 2>/dev/null)
    local enforce_admins=$(echo "$protection" | jq '.enforce_admins.enabled // false' 2>/dev/null)
    info "PR reviews required: $pr_required"
    info "Status checks required: $status_checks"
    info "Enforce for admins: $enforce_admins"
    if [[ "$enforce_admins" != "true" ]]; then
      warn "Branch protection does not enforce on admins"
    else
      ok "Branch protection active and enforced"
    fi
  fi

  # --- Secrets scanning alerts ---
  header "Secret Scanning Alerts"
  local secrets
  secrets=$(gh api "repos/$repo/secret-scanning/alerts?state=open&per_page=10" 2>/dev/null || echo "UNAVAILABLE")
  if [[ "$secrets" == "UNAVAILABLE" || $(echo "$secrets" | jq 'has("message")' 2>/dev/null) == "true" ]]; then
    info "Secret scanning not available (requires GitHub Advanced Security)"
  else
    local secret_count=$(echo "$secrets" | jq 'length')
    if [[ "$secret_count" -gt 0 ]]; then
      alert "$secret_count open secret scanning alert(s)!"
      echo "$secrets" | jq -r '.[] | "    \(.secret_type_display_name // .secret_type) — created \(.created_at)"'
    else
      ok "No open secret scanning alerts"
    fi
  fi

  echo ""
}

# --- Main ---
echo -e "${BOLD}"
echo "   ╔════════════════════════════════════════════╗"
echo "   ║         gh-audit v${VERSION}                   ║"
echo "   ║    GitHub Repository Security Audit       ║"
echo "   ╚════════════════════════════════════════════╝"
echo -e "${NC}"
echo -e "  Authenticated as: ${CYAN}${AUTHED_USER}${NC}"
echo -e "  Lookback window:  ${SINCE} days (since ${SINCE_DATE})"
echo -e "  Repos to audit:   ${#REPOS[@]}"

for repo in "${REPOS[@]}"; do
  audit_repo "$repo"
done

# --- Summary ---
echo -e "\n${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BOLD}  Summary${NC}"
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  Repos audited: ${#REPOS[@]}"
echo -e "  Warnings:      ${YELLOW}${WARNINGS}${NC}"
echo -e "  Alerts:        ${RED}${ALERTS}${NC}"

if [[ "$ALERTS" -gt 0 ]]; then
  echo -e "\n  ${RED}${BOLD}Action required — review alerts above.${NC}"
  echo -e "  ${DIM}If you suspect compromise, rotate tokens immediately:${NC}"
  echo -e "  ${DIM}  gh auth refresh${NC}"
  echo -e "  ${DIM}  https://github.com/settings/tokens${NC}"
  exit 2
elif [[ "$WARNINGS" -gt 0 ]]; then
  echo -e "\n  ${YELLOW}Some items need review.${NC}"
  exit 1
else
  echo -e "\n  ${GREEN}${BOLD}All clear — no issues found.${NC}"
  exit 0
fi
